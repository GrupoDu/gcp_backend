        "responses": {
          "200": {
            "description": "Meta removida com sucesso"
          },
          "403": {
            "description": "Acesso negado"
          },
          "500": {
            "description": "Erro interno do servidor"
          }
        }
      },
      "put": {
        "summary": "Atualiza uma meta (Apenas Admin)",
        "tags": ["Goals"],
        "security": [{ "cookieAuth": [] }],
        "parameters": [
          {
            "name": "uuid",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "minProperties": 1,
                "properties": {
                  "goal_id": { "type": "string" },
                  "goal_title": { "type": "string" },
                  "goal_description": { "type": "string", "nullable": true },
                  "goal_type": { "type": "string" },
