{
  "openapi": "3.0.0",
  "info": {
    "title": "GCP Backend API",
    "description": "API para gerenciamento de metas, usuários, produtos, funcionários e análises",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://gcp-backend-gnxf.onrender.com",
      "description": "Servidor de Produção"
    }
  ],
  "components": {
    "securitySchemes": {
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "token",
        "description": "Autenticação via cookie HttpOnly contendo o token JWT"
      }
    },
    "schemas": {
      "LoginRequest": {
        "type": "object",
        "required": ["email", "senha", "user_type"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "senha": { "type": "string", "format": "password" },
          "user_type": { "type": "string" }
        }
      },
      "Goal": {
        "type": "object",
        "required": [
          "goal_id",
          "goal_title",
          "goal_type",
          "goal_deadline",
          "goal_status"
        ],
        "properties": {
          "goal_id": { "type": "string" },
          "goal_title": { "type": "string" },
          "goal_description": { "type": "string", "nullable": true },
          "goal_type": { "type": "string" },
          "goal_deadline": { "type": "string", "format": "date-time" },
          "employee_goal": { "type": "string", "nullable": true },
          "goal_status": { "type": "string" }
        }
      },
      "User": {
        "type": "object",
        "required": ["name", "email", "password", "user_type"],
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "format": "password" },
          "user_type": { "type": "string" }
        }
      },
      "Product": {
        "type": "object",
        "required": ["name", "description", "product_type", "image"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "product_type": { "type": "string" },
          "image": { "type": "string" },
          "features": {
            "type": "array",
            "items": { "type": "string" }
          },
          "acronym": { "type": "string", "nullable": true },
          "composition": {
            "type": "object",
            "description": "Campo JSON flexível"
          },
          "stock_quantity": {
            "type": "number",
            "format": "decimal"
          }
        }
      },
      "Employee": {
        "type": "object",
        "required": ["name", "employee_type"],
        "properties": {
          "name": { "type": "string" },
          "employee_type": { "type": "string" }
        }
      },
      "ProducedQuantity": {
        "type": "object",
        "required": ["productsQuantity"],
        "properties": {
          "productsQuantity": { "type": "number" }
        }
      },
      "Feedback": {
        "type": "object",
        "required": ["card_name", "card_description"],
        "properties": {
          "card_name": { "type": "string" },
          "card_description": { "type": "string" }
        }
      },
      "ProductionOrder": {
        "type": "object",
        "required": [
          "production_order_title",
          "production_order_deadline",
          "product_quantity",
          "product_uuid",
          "client_uuid"
        ],
        "properties": {
          "production_order_title": { "type": "string" },
          "production_order_description": {
            "type": "string",
            "nullable": true
          },
          "production_order_deadline": {
            "type": "string",
            "format": "date-time"
          },
          "product_quantity": { "type": "number", "format": "decimal" },
          "cut_assistant": { "type": "string", "nullable": true },
          "fold_assistant": { "type": "string", "nullable": true },
          "finishing_assistant": { "type": "string", "nullable": true },
          "paint_assistant": { "type": "string", "nullable": true },
          "employee_uuid": { "type": "string", "nullable": true },
          "product_uuid": { "type": "string" },
          "client_uuid": { "type": "string" }
        }
      },
      "DeliveryOrder": {
        "type": "object",
        "required": [
          "delivered_product_quantity",
          "requested_product_quantity"
        ],
        "properties": {
          "delivered_product_quantity": { "type": "number" },
          "requested_product_quantity": { "type": "number" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "message": { "type": "string" },
          "code": { "type": "integer" }
        }
      }
    }
  },
  "security": [{ "cookieAuth": [] }],
  "paths": {
    "/login": {
      "post": {
        "summary": "Realiza login do usuário",
        "tags": ["Login"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login realizado com sucesso"
          },
          "401": {
            "description": "Credenciais inválidas"
          },
          "500": {
            "description": "Erro interno do servidor"
          }
        }
      }
    },
    "/login/refresh": {
      "post": {
        "summary": "Renova o token de acesso",
        "tags": ["Login"],
        "responses": {
          "200": {
            "description": "Token renovado com sucesso"
          },
          "401": {
            "description": "Não autorizado"
          }
        }
      }
    },
    "/login/verify": {
      "get": {
        "summary": "Verifica se o token é válido",
        "tags": ["Login"],
        "responses": {
          "200": {
            "description": "Token válido"
          },
          "401": {
            "description": "Token inválido"
          }
        }
      }
    },
    "/login/logout": {
      "post": {
        "summary": "Realiza logout do usuário",
        "tags": ["Login"],
        "responses": {
          "200": {
            "description": "Logout realizado com sucesso"
          }
        }
      }
    },
    "/goals": {
      "get": {
        "summary": "Lista todas as metas",
        "tags": ["Goals"],
        "responses": {
          "200": {
            "description": "Lista de metas retornada com sucesso",
