generator client {
  provider = "prisma-client"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model user {
  user_id   String     @id(map: "users_pkey") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  email     String
  password  String
  user_type String
  register  register[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model products {
  created_at   DateTime   @default(now()) @db.Timestamptz(6)
  name         String     @unique(map: "produtos_nome_key")
  description  String
  product_type String
  image        String
  features     String[]
  acronym      String?
  composition  Json       @default("{}")
  uuid         String     @id(map: "produtos_pkey") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  register     register[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model employee {
  employee_id                                     String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                            String
  employee_type                                   String
  goal                                            goal[]
  register_register_cut_assistantToemployee       register[] @relation("register_cut_assistantToemployee")
  register_register_employee_uuidToemployee       register[] @relation("register_employee_uuidToemployee")
  register_register_finishing_assistantToemployee register[] @relation("register_finishing_assistantToemployee")
  register_register_fold_assistantToemployee      register[] @relation("register_fold_assistantToemployee")
  register_register_paint_assistantToemployee     register[] @relation("register_paint_assistantToemployee")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model goal {
  goal_id       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  title         String
  description   String?
  goal_type     String
  deadline      DateTime  @db.Date
  employee_goal String?   @db.Uuid
  employee      employee? @relation(fields: [employee_goal], references: [employee_id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model register {
  register_id                                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at                                      DateTime  @default(now()) @db.Timestamptz(6)
  title                                           String
  deadline                                        DateTime  @db.Date
  status                                          String    @default("Pendente")
  product_quantity                                Decimal   @db.Decimal
  delivered_at                                    DateTime? @db.Date
  cut_assistant                                   String?   @db.Uuid
  fold_assistant                                  String?   @db.Uuid
  finishing_assistant                             String?   @db.Uuid
  paint_assistant                                 String?   @db.Uuid
  employee_uuid                                   String?   @db.Uuid
  product_uuid                                    String    @db.Uuid
  client_uuid                                     String    @db.Uuid
  description                                     String?
  deliver_observation                             String?
  is_delivered                                    Boolean   @default(false)
  user                                            user      @relation(fields: [client_uuid], references: [user_id], onDelete: SetNull)
  employee_register_cut_assistantToemployee       employee? @relation("register_cut_assistantToemployee", fields: [cut_assistant], references: [employee_id])
  employee_register_employee_uuidToemployee       employee? @relation("register_employee_uuidToemployee", fields: [employee_uuid], references: [employee_id])
  employee_register_finishing_assistantToemployee employee? @relation("register_finishing_assistantToemployee", fields: [finishing_assistant], references: [employee_id])
  employee_register_fold_assistantToemployee      employee? @relation("register_fold_assistantToemployee", fields: [fold_assistant], references: [employee_id])
  employee_register_paint_assistantToemployee     employee? @relation("register_paint_assistantToemployee", fields: [paint_assistant], references: [employee_id])
  products                                        products  @relation(fields: [product_uuid], references: [uuid], onDelete: SetNull)
}
