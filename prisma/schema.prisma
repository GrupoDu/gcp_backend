generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model products {
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  name             String             @unique(map: "produtos_nome_key")
  description      String
  product_type     String
  image            String
  features         String[]
  acronym          String?
  composition      Json               @default("{}")
  uuid             String             @id(map: "produtos_pkey") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stock_quantity   Decimal            @default(0) @db.Decimal
  production_order production_order[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model anualAnalysis {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  month         Decimal   @db.Decimal
  year          Decimal   @db.Decimal
  delivered     Decimal   @db.Decimal
  not_delivered Decimal   @db.Decimal
  updated_at    DateTime? @db.Date

  @@unique([year, month], map: "unique_year_month")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model employees {
  employee_id                                                      String                  @id(map: "employee_pkey") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                                             String
  employee_type                                                    String
  delivered_activities_quantity                                    Decimal                 @default(0) @db.Decimal
  not_delivered_activities_quantity                                Decimal                 @default(0) @db.Decimal
  produced_quantity                                                Decimal                 @default(0) @db.Decimal
  assistant_analysis                                               assistant_analysis[]
  assitants_po_register                                            assitants_po_register[]
  goals                                                            goals[]
  production_order_production_order_cut_assistantToemployees       production_order[]      @relation("production_order_cut_assistantToemployees")
  production_order_production_order_employee_uuidToemployees       production_order[]      @relation("production_order_employee_uuidToemployees")
  production_order_production_order_finishing_assistantToemployees production_order[]      @relation("production_order_finishing_assistantToemployees")
  production_order_production_order_fold_assistantToemployees      production_order[]      @relation("production_order_fold_assistantToemployees")
  production_order_production_order_paint_assistantToemployees     production_order[]      @relation("production_order_paint_assistantToemployees")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model goals {
  goal_id          String     @id(map: "goal_pkey") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at       DateTime   @default(now()) @db.Timestamptz(6)
  goal_title       String
  goal_description String?
  goal_type        String
  goal_deadline    DateTime   @db.Date
  employee_goal    String?    @db.Uuid
  goal_status      String     @default("Pendente")
  employees        employees? @relation(fields: [employee_goal], references: [employee_id], onDelete: Cascade, map: "goal_employee_goal_fkey")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  user_id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  email            String
  password         String
  user_type        String
  production_order production_order[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model production_order {
  production_order_id                                       String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at                                                DateTime                @default(now()) @db.Timestamptz(6)
  production_order_title                                    String
  production_order_deadline                                 DateTime                @db.Date
  production_order_status                                   String                  @default("Pendente")
  product_quantity                                          Decimal                 @db.Decimal
  delivered_at                                              DateTime?               @db.Date
  cut_assistant                                             String?                 @db.Uuid
  fold_assistant                                            String?                 @db.Uuid
  finishing_assistant                                       String?                 @db.Uuid
  paint_assistant                                           String?                 @db.Uuid
  employee_uuid                                             String?                 @db.Uuid
  product_uuid                                              String                  @db.Uuid
  client_uuid                                               String                  @db.Uuid
  production_order_description                              String?
  delivery_observation                                      String?
  delivered_product_quantity                                Decimal                 @default(0) @db.Decimal
  assistant_analysis                                        assistant_analysis[]
  assitants_po_register                                     assitants_po_register[]
  users                                                     users                   @relation(fields: [client_uuid], references: [user_id], onDelete: Cascade, map: "register_client_uuid_fkey")
  employees_production_order_cut_assistantToemployees       employees?              @relation("production_order_cut_assistantToemployees", fields: [cut_assistant], references: [employee_id], map: "register_cut_assistant_fkey")
  employees_production_order_employee_uuidToemployees       employees?              @relation("production_order_employee_uuidToemployees", fields: [employee_uuid], references: [employee_id], map: "register_employee_uuid_fkey")
  employees_production_order_finishing_assistantToemployees employees?              @relation("production_order_finishing_assistantToemployees", fields: [finishing_assistant], references: [employee_id], map: "register_finishing_assistant_fkey")
  employees_production_order_fold_assistantToemployees      employees?              @relation("production_order_fold_assistantToemployees", fields: [fold_assistant], references: [employee_id], map: "register_fold_assistant_fkey")
  employees_production_order_paint_assistantToemployees     employees?              @relation("production_order_paint_assistantToemployees", fields: [paint_assistant], references: [employee_id], map: "register_paint_assistant_fkey")
  products                                                  products                @relation(fields: [product_uuid], references: [uuid], onDelete: SetNull, map: "register_product_uuid_fkey")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model refresh_tokens {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  token      String   @unique
  user_uuid  String   @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  expires_at DateTime @db.Date
  revoked    Boolean
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model in_out_stock {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  month        Int
  year         Int
  in_quantity  Int      @default(0)
  out_quantity Int      @default(0)
  updated_at   DateTime @default(now()) @db.Date
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model stock_updates {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at             DateTime @default(now()) @db.Timestamptz(6)
  product_quantity_title String
  event                  String
  date                   DateTime @db.Date
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model assistant_analysis {
  assistant_analysis_uuid String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at              DateTime         @default(now()) @db.Timestamptz(6)
  delivered_quantity      Int              @default(0) @db.SmallInt
  not_delivered_quantity  Int              @default(0) @db.SmallInt
  assistant_uuid          String           @db.Uuid
  production_order_uuid   String           @db.Uuid
  employees               employees        @relation(fields: [assistant_uuid], references: [employee_id], onDelete: NoAction, onUpdate: NoAction)
  production_order        production_order @relation(fields: [production_order_uuid], references: [production_order_id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model assitants_po_register {
  assistants_po_registers_uuid String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  delivered                    Boolean          @default(false)
  delivered_at                 DateTime?        @db.Date
  production_order_uuid        String           @db.Uuid
  assistant_uuid               String           @db.Uuid
  assistant_as                 String
  employees                    employees        @relation(fields: [assistant_uuid], references: [employee_id], onDelete: NoAction, onUpdate: NoAction)
  production_order             production_order @relation(fields: [production_order_uuid], references: [production_order_id], onDelete: NoAction, onUpdate: NoAction)
}
