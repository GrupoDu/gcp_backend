generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model annual_analysis {
  anual_analysis_uuid String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at          DateTime? @db.Timestamptz(6)
  month               Int
  year                Int
  delivered           Int       @default(0)
  not_delivered       Int       @default(0)
  updated_at          DateTime  @default(now()) @db.Date
}

model assistants_po_register {
  assistants_po_registers_uuid String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  delivered                    Boolean          @default(false)
  delivered_at                 DateTime?        @db.Date
  assistant_as                 String
  production_order_uuid        String           @db.Uuid
  assistant_uuid               String           @db.Uuid
  produced_quantity            Int              @default(0)
  employees                    employees        @relation(fields: [assistant_uuid], references: [employee_uuid], onDelete: NoAction, onUpdate: NoAction)
  production_order             production_order @relation(fields: [production_order_uuid], references: [production_order_uuid], onDelete: NoAction, onUpdate: NoAction)
}

model employees {
  employee_uuid                                                    String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                                             String
  employee_role                                                    String
  delivered_activities_quantity                                    Int                      @default(0)
  not_delivered_activities_quantity                                Int                      @default(0)
  produced_quantity                                                Int                      @default(0)
  assistants_po_register                                           assistants_po_register[]
  goals                                                            goals[]
  production_order_production_order_cut_assistantToemployees       production_order[]       @relation("production_order_cut_assistantToemployees")
  production_order_production_order_employee_uuidToemployees       production_order[]       @relation("production_order_employee_uuidToemployees")
  production_order_production_order_finishing_assistantToemployees production_order[]       @relation("production_order_finishing_assistantToemployees")
  production_order_production_order_fold_assistantToemployees      production_order[]       @relation("production_order_fold_assistantToemployees")
  production_order_production_order_paint_assistantToemployees     production_order[]       @relation("production_order_paint_assistantToemployees")
}

model goals {
  goal_uuid        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at       DateTime   @default(now()) @db.Timestamptz(6)
  goal_title       String
  goal_description String?
  goal_type        String     @default("Geral")
  goal_deadline    DateTime   @db.Date
  goal_status      String
  employee_goal    String?    @db.Uuid
  employees        employees? @relation(fields: [employee_goal], references: [employee_uuid], onDelete: NoAction, onUpdate: NoAction)
}

model in_out_stock {
  in_out_stock_uuid String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  month             Int
  year              Int
  in_quantity       Int      @default(0)
  out_quantity      Int      @default(0)
  updated_at        DateTime @default(now()) @db.Date
}

model materials {
  material_uuid     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  material_name     String
  material_quantity Int?
}

model order_items {
  order_item_uuid     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  quantity            Int      @default(1)
  unit_price          Int
  discount_percentage Float    @default(0)
  ipi                 Float    @default(0)
  additional_amount   Int      @default(0)
  total               Int
  product_uuid        String   @db.Uuid
  order_uuid          String   @db.Uuid
  orders              orders   @relation(fields: [order_uuid], references: [order_uuid], onDelete: NoAction, onUpdate: NoAction)
  products            products @relation(fields: [product_uuid], references: [product_uuid], onDelete: NoAction, onUpdate: NoAction)
}

model orders {
  order_uuid       String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  order_status     String             @default("Ainda não confirmado")
  order_deadline   DateTime           @db.Date
  billing_uuid     String             @db.Uuid
  revenue_uuid     String             @db.Uuid
  client_uuid      String             @db.Uuid
  billing          billing            @relation(fields: [billing_uuid], references: [billing_uuid], onDelete: NoAction, onUpdate: NoAction)
  revenue          revenues           @relation(fields: [revenue_uuid], references: [revenue_uuid], onDelete: NoAction, onUpdate: NoAction)
  clients          clients            @relation(fields: [client_uuid], references: [client_uuid], onDelete: NoAction, onUpdate: NoAction)
  totalPrice       Int                @default(0)
  delivery         deliveries?
  order_items      order_items[]
  production_order production_order[]
}

model revenues {
  revenue_uuid     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  client_uuid      String   @db.Uuid
  revenue_address  String
  revenue_cnpj     String
  revenue_phone    String
  revenue_email    String
  revenue_landline String?
  clients          clients  @relation(fields: [client_uuid], references: [client_uuid], onDelete: NoAction, onUpdate: NoAction)
  orders           orders[]
}

model billing {
  billing_uuid    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  client_uuid     String   @db.Uuid
  billing_address String
  name            String?
  clients         clients  @relation(fields: [client_uuid], references: [client_uuid], onDelete: NoAction, onUpdate: NoAction)
  orders          orders[]
}

model clients {
  client_uuid     String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at      DateTime   @default(now()) @db.Timestamptz(6)
  client_name     String
  client_cnpj     String
  client_address  String
  client_phone    String
  client_landline String?
  revenues        revenues[]
  billings        billing[]
  orders          orders[]
}


model deliveries {
  delivery_uuid        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at           DateTime @default(now()) @db.Timestamptz(6)
  order_uuid           String   @unique @db.Uuid
  delivery_address     String
  building             String
  reference            String?
  delivery_observation String?
  orders               orders   @relation(fields: [order_uuid], references: [order_uuid], onDelete: NoAction, onUpdate: NoAction)
}

model production_order {
  production_order_uuid                                     String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at                                                DateTime                 @default(now()) @db.Timestamptz(6)
  production_order_title                                    String
  production_order_description                              String?
  production_order_deadline                                 DateTime                 @db.Date
  production_order_status                                   String                   @default("Pendente")
  product_quantity                                          Int                      @default(0)
  product_uuid                                              String                   @db.Uuid
  delivered_at                                              DateTime?                @db.Date
  delivery_observation                                      String?
  delivered_product_quantity                                Int                      @default(0)
  stock_validation                                          Boolean                  @default(false)
  order_uuid                                                String?                  @db.Uuid
  cut_assistant                                             String?                  @db.Uuid
  fold_assistant                                            String?                  @db.Uuid
  finishing_assistant                                       String?                  @db.Uuid
  paint_assistant                                           String?                  @db.Uuid
  employee_uuid                                             String?                  @db.Uuid
  supervisor_uuid                                           String?                  @db.Uuid
  assistants_po_register                                    assistants_po_register[]
  employees_production_order_cut_assistantToemployees       employees?               @relation("production_order_cut_assistantToemployees", fields: [cut_assistant], references: [employee_uuid], onDelete: NoAction, onUpdate: NoAction)
  employees_production_order_employee_uuidToemployees       employees?               @relation("production_order_employee_uuidToemployees", fields: [employee_uuid], references: [employee_uuid], onDelete: NoAction, onUpdate: NoAction)
  employees_production_order_finishing_assistantToemployees employees?               @relation("production_order_finishing_assistantToemployees", fields: [finishing_assistant], references: [employee_uuid], onDelete: NoAction, onUpdate: NoAction)
  employees_production_order_fold_assistantToemployees      employees?               @relation("production_order_fold_assistantToemployees", fields: [fold_assistant], references: [employee_uuid], onDelete: NoAction, onUpdate: NoAction)
  orders                                                    orders?                  @relation(fields: [order_uuid], references: [order_uuid], onDelete: NoAction, onUpdate: NoAction)
  employees_production_order_paint_assistantToemployees     employees?               @relation("production_order_paint_assistantToemployees", fields: [paint_assistant], references: [employee_uuid], onDelete: NoAction, onUpdate: NoAction)
  users                                                     users?                   @relation(fields: [supervisor_uuid], references: [user_uuid], onDelete: NoAction, onUpdate: NoAction)
  products                                                  products                 @relation(fields: [product_uuid], references: [product_uuid], onDelete: Cascade, onUpdate: NoAction)
}

model products {
  product_uuid     String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  name             String             @unique
  product_type     String
  image            String
  features         String[]
  stock_quantity   Int                @default(0)
  order_items      order_items[]
  unit_price       Int
  productionOrders production_order[]
  acronym          String?
  composition      Json?
  description      String?
}

model refresh_tokens {
  refresh_token_uuid String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  token              String   @unique
  expires_at         DateTime @db.Date
  is_revoked         Boolean  @default(false)
  user_uuid          String   @db.Uuid
  users              users    @relation(fields: [user_uuid], references: [user_uuid], onDelete: NoAction, onUpdate: NoAction)
}

model stock_updates {
  stock_updates_uuid     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at             DateTime @default(now()) @db.Timestamptz(6)
  product_quantity_title String
  event                  String
  date                   DateTime @db.Date
}

model users {
  user_uuid        String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  email            String
  password         String
  user_role        String
  is_active        Boolean            @default(true)
  production_order production_order[]
  refresh_tokens   refresh_tokens[]
}
