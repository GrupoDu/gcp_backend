{
  "name": "gcp_backend",
  "version": "1.0.0",
  "description": "Esse repositório guarda todo o backend do **Gerenciador de Controle de Produção**.\r #### [Repositório geral do GCP](https://github.com/GrupoDu/gerenciador_de_controle_de_producao?tab=GPL-3.0-1-ov-file#readme).\r ## Rodando o projeto",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "build": "prisma generate && echo 'Rodando tsc...' && tsc && echo 'tsc concluido.'",
    "build:dev": "prisma generate && echo 'Rodando tsc...' && tsc && echo 'tsc concluido.'",
    "start": "node dist/src/server.js",
    "build:start": "npm run build && npm run start",
    "dev": "npx tsx src/server.ts --watch",
    "generate:api": "npx swagger-typescript-api generate --path ./swagger.json",
    "prisma:pull": "npx prisma db pull && npx prisma generate",
    "prettier": "prettier --write ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GrupoDu/gcp_backend.git"
  },
